{
  "agent_pid": {
    "description": "One-sentence what this agent does",
    "input_schema": {
      "type": "string",
      "description": "What kind of input this agent expects — query, code task, data, etc."
    },
    "output_schema": {
      "type": "string",
      "format": "Expected output format — markdown, code block, bullet list, etc."
    },
    "max_turns": 5,
    "allowed_tools": [
      "read_file",
      "write_file",
      "terminal",
      "search_files",
      "web_search",
      "web_extract"
    ],
    "prohibited_tools": [
      "patch",
      "write_file (external paths)"
    ],
    "quality_constraints": {
      "non_empty": true,
      "no_error_signals": true,
      "no_roleplay_preamble": true,
      "has_code_block": false,
      "has_sources": false,
      "min_length": 10
    },
    "cost_tier": "fast|heavy|guardrail|review",
    "fallback_agent": "alternative_agent_pid",
    "notes": "Any special constraints or behaviors for this agent"
  }
}
